{
  "realm": "gain",
  "enabled": true,
  "displayName": "GAIN Identity",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "sslRequired": "external",
  "roles": {
    "realm": [
      { "name": "platform_super_admin" },
      { "name": "org_owner" },
      { "name": "org_admin" },
      { "name": "org_member" },
      { "name": "org_viewer" }
    ]
  },
  "clients": [
    {
      "clientId": "gain-identity-api",
      "name": "GAIN Identity API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "change_me_identity_api_secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:3001/*"],
      "webOrigins": ["http://localhost:3001"],
      "attributes": {
        "access.token.lifespan": "900"
      }
    },
    {
      "clientId": "gain-web",
      "name": "GAIN Web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3000/api/auth/callback/keycloak"
      ],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "admin@gain.network",
      "email": "admin@gain.network",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Platform",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "GainAdmin!2026",
          "temporary": false
        }
      ],
      "realmRoles": ["platform_super_admin", "org_owner"]
    }
  ]
}
