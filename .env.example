# Database
DATABASE_URL=postgresql://gain:gain_secret_change_me@localhost:5432/gain_identity?schema=public

# Identity API
IDENTITY_API_PORT=3001
IDENTITY_API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=gain-identity-api
KAFKA_GROUP_ID=gain-identity-api

# Keycloak
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=gain
KEYCLOAK_CLIENT_ID=gain-identity-api
KEYCLOAK_CLIENT_SECRET=change_me_identity_api_secret
KEYCLOAK_ISSUER=http://localhost:8080/realms/gain
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/gain/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=gain-identity-api

# Rate limiting
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120

# Web
NEXT_PUBLIC_IDENTITY_API_URL=http://localhost:3001
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=gain
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=gain-web
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_nextauth_secret_min_32_chars_long
KEYCLOAK_WEB_CLIENT_SECRET=

# Observability
OTEL_SERVICE_NAME=gain-identity-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
