    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@gain/tsconfig": "workspace:*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
