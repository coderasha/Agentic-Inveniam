  description       String?                  @db.VarChar(4000)
  sellerRef         String                   @map("seller_ref") @db.VarChar(200)
  currencyCode      String                   @default("USD") @map("currency_code") @db.Char(3)
  priceMinor        BigInt                   @map("price_minor")
  quantity          BigInt
  quantityRemaining BigInt                   @map("quantity_remaining")
  status            MarketplaceListingStatus @default(open)
  expiresAt         DateTime?                @map("expires_at") @db.Timestamptz(3)
  metadata          Json                     @default("{}")
  version           Int                      @default(1)
  createdByUserId   String?                  @map("created_by_user_id") @db.Uuid
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt         DateTime?                @map("deleted_at") @db.Timestamptz(3)

  orders MarketplaceOrder[]
  trades MarketplaceTrade[]

  @@index([organizationId, status, createdAt])
  @@index([organizationId, subjectType, subjectId])
  @@index([expiresAt])
  @@map("marketplace_listings")
}

model MarketplaceOrder {
  id              String                 @id @default(uuid()) @db.Uuid
  organizationId  String                 @map("organization_id") @db.Uuid
  listingId       String                 @map("listing_id") @db.Uuid
  buyerRef        String                 @map("buyer_ref") @db.VarChar(200)
  orderType       MarketplaceOrderType   @default(limit) @map("order_type")
  priceMinor      BigInt?                @map("price_minor")
  quantity        BigInt
  filledQuantity  BigInt                 @default(0) @map("filled_quantity")
  status          MarketplaceOrderStatus @default(open)
  metadata        Json                   @default("{}")
  createdByUserId String?                @map("created_by_user_id") @db.Uuid
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  trades  MarketplaceTrade[]

  @@index([organizationId, status, createdAt])
  @@index([listingId, status])
  @@map("marketplace_orders")
}

model MarketplaceTrade {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  listingId      String                 @map("listing_id") @db.Uuid
  orderId        String                 @map("order_id") @db.Uuid
  sellerRef      String                 @map("seller_ref") @db.VarChar(200)
  buyerRef       String                 @map("buyer_ref") @db.VarChar(200)
  priceMinor     BigInt                 @map("price_minor")
  quantity       BigInt
  notionalMinor  BigInt                 @map("notional_minor")
  currencyCode   String                 @map("currency_code") @db.Char(3)
  status         MarketplaceTradeStatus @default(settled)
  settlementRef  String?                @map("settlement_ref") @db.VarChar(200)
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  order   MarketplaceOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([listingId, createdAt])
  @@index([orderId])
  @@map("marketplace_trades")
}

// ─── Portfolio OS ────────────────────────────────────────────────────────────

enum PortfolioStatus {
  draft
  active
  archived
}

enum PortfolioPositionSubjectType {
  asset
  twin
  token_instrument
  custom
}

model Portfolio {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  name           String          @db.VarChar(200)
  slug           String          @db.VarChar(120)
  description    String?         @db.VarChar(2000)
  status         PortfolioStatus @default(active)
  baseCurrency   String          @default("USD") @map("base_currency") @db.Char(3)
  metadata       Json            @default("{}")
  version        Int             @default(1)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz(3)

  positions PortfolioPosition[]
  snapshots PortfolioSnapshot[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("portfolios")
}

model PortfolioPosition {
  id               String                       @id @default(uuid()) @db.Uuid
  organizationId   String                       @map("organization_id") @db.Uuid
  portfolioId      String                       @map("portfolio_id") @db.Uuid
  subjectType      PortfolioPositionSubjectType @map("subject_type")
  subjectId        String                       @map("subject_id") @db.Uuid
  label            String                       @db.VarChar(300)
  quantity         Decimal                      @db.Decimal(24, 8)
  costBasisMinor   BigInt                       @default(0) @map("cost_basis_minor")
  marketValueMinor BigInt                       @default(0) @map("market_value_minor")
  weightHint       Float?                       @map("weight_hint")
  metadata         Json                         @default("{}")
  createdAt        DateTime                     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt        DateTime?                    @map("deleted_at") @db.Timestamptz(3)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, subjectType, subjectId])
  @@index([organizationId, portfolioId])
  @@map("portfolio_positions")
}

model PortfolioSnapshot {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  portfolioId      String   @map("portfolio_id") @db.Uuid
  asOfDate         DateTime @map("as_of_date") @db.Date
  baseCurrency     String   @map("base_currency") @db.Char(3)
  navMinor         BigInt   @map("nav_minor")
  costBasisMinor   BigInt   @map("cost_basis_minor")
  unrealizedPnlMinor BigInt @map("unrealized_pnl_minor")
  positionCount    Int      @map("position_count")
  breakdown        Json     @default("{}")
  createdByUserId  String?  @map("created_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, asOfDate])
  @@index([organizationId, asOfDate])
  @@map("portfolio_snapshots")
}

// ─── Investor CRM ────────────────────────────────────────────────────────────

enum InvestorType {
  individual
  family_office
  institution
  fund
  advisor
  other
}

enum InvestorStatus {
  prospect
  qualified
  active
  inactive
  do_not_contact
}

enum InvestorPipelineStage {
  lead
  contacted
  meeting
  diligence
  committed
  closed
  lost
}

enum InteractionChannel {
  email
  call
  meeting
  note
  event
  other
}

enum CommitmentStatus {
  soft
  hard
  funded
  cancelled
}

model Investor {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  displayName    String                @map("display_name") @db.VarChar(200)
  investorType   InvestorType          @default(individual) @map("investor_type")
  status         InvestorStatus        @default(prospect)
  pipelineStage  InvestorPipelineStage @default(lead) @map("pipeline_stage")
  email          String?               @db.VarChar(320)
  phone          String?               @db.VarChar(40)
  company        String?               @db.VarChar(200)
  countryCode    String?               @map("country_code") @db.Char(2)
  ownerRef       String?               @map("owner_ref") @db.VarChar(200)
  tags           String[]              @default([])
  metadata       Json                  @default("{}")
  version        Int                   @default(1)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime?             @map("deleted_at") @db.Timestamptz(3)

  interactions InvestorInteraction[]
  commitments  InvestorCommitment[]

  @@index([organizationId, status, pipelineStage])
  @@index([organizationId, displayName])
  @@index([email])
  @@map("investors")
}

model InvestorInteraction {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  investorId     String             @map("investor_id") @db.Uuid
  channel        InteractionChannel @default(note)
  subject        String             @db.VarChar(300)
  body           String?            @db.VarChar(8000)
  occurredAt     DateTime           @default(now()) @map("occurred_at") @db.Timestamptz(3)
  metadata       Json               @default("{}")
  createdByUserId String?           @map("created_by_user_id") @db.Uuid
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([organizationId, investorId, occurredAt])
  @@map("investor_interactions")
}

model InvestorCommitment {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  investorId     String           @map("investor_id") @db.Uuid
  portfolioId    String?          @map("portfolio_id") @db.Uuid
  label          String           @db.VarChar(200)
  amountMinor    BigInt           @map("amount_minor")
  currencyCode   String           @default("USD") @map("currency_code") @db.Char(3)
  status         CommitmentStatus @default(soft)
  committedAt    DateTime         @default(now()) @map("committed_at") @db.Timestamptz(3)
  metadata       Json             @default("{}")
  createdByUserId String?         @map("created_by_user_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([organizationId, investorId, status])
  @@index([portfolioId])
  @@map("investor_commitments")
}

// ─── Compliance ──────────────────────────────────────────────────────────────

enum CompliancePolicyStatus {
  draft
  active
  archived
}

enum ComplianceSubjectType {
  asset
  twin
  document
  investor
  portfolio
  token_instrument
  organization
  custom
}

enum ComplianceCheckStatus {
  passed
  failed
  warning
  error
}

enum ComplianceFindingSeverity {
  low
  medium
  high
  critical
}

enum ComplianceFindingStatus {
  open
  accepted
  remediated
  waived
}

enum ComplianceCaseStatus {
  open
  in_progress
  resolved
  closed
}

model CompliancePolicy {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  name           String                  @db.VarChar(200)
  slug           String                  @db.VarChar(120)
  description    String?                 @db.VarChar(2000)
  subjectType    ComplianceSubjectType   @map("subject_type")
  status         CompliancePolicyStatus  @default(active)
  rules          Json
  version        Int                     @default(1)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime?               @map("deleted_at") @db.Timestamptz(3)

  checks ComplianceCheck[]

  @@unique([organizationId, slug])
  @@index([organizationId, status, subjectType])
  @@map("compliance_policies")
}

model ComplianceCheck {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  policyId       String                @map("policy_id") @db.Uuid
  subjectType    ComplianceSubjectType @map("subject_type")
  subjectId      String                @map("subject_id") @db.Uuid
  status         ComplianceCheckStatus
  summary        String                @db.VarChar(1000)
  subjectSnapshot Json                 @map("subject_snapshot")
  createdByUserId String?              @map("created_by_user_id") @db.Uuid
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)

  policy   CompliancePolicy    @relation(fields: [policyId], references: [id], onDelete: Cascade)
  findings ComplianceFinding[]
  cases    ComplianceCase[]

  @@index([organizationId, status, createdAt])
  @@index([policyId, createdAt])
  @@index([subjectType, subjectId])
  @@map("compliance_checks")
}

model ComplianceFinding {
  id             String                    @id @default(uuid()) @db.Uuid
  organizationId String                    @map("organization_id") @db.Uuid
  checkId        String                    @map("check_id") @db.Uuid
  ruleId         String                    @map("rule_id") @db.VarChar(64)
  severity       ComplianceFindingSeverity
  status         ComplianceFindingStatus   @default(open)
  message        String                    @db.VarChar(500)
  details        Json                      @default("{}")
  createdAt      DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(3)

  check ComplianceCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, severity])
  @@index([checkId])
  @@map("compliance_findings")
}

model ComplianceCase {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  checkId        String               @map("check_id") @db.Uuid
  title          String               @db.VarChar(300)
  status         ComplianceCaseStatus @default(open)
  assigneeRef    String?              @map("assignee_ref") @db.VarChar(200)
  notes          String?              @db.VarChar(4000)
  dueAt          DateTime?            @map("due_at") @db.Timestamptz(3)
  resolvedAt     DateTime?            @map("resolved_at") @db.Timestamptz(3)
  createdByUserId String?             @map("created_by_user_id") @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  check ComplianceCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt])
  @@index([checkId])
  @@map("compliance_cases")
}
